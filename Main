function Toast({notif}){
  if(!notif) return null;
  return(
    <div style={{position:"fixed",bottom:24,right:24,
      background:C.bgCard,border:`1px solid ${notif.color}44`,
      borderRadius:10,padding:"12px 16px",minWidth:220,
      boxShadow:`0 0 24px ${notif.color}33,0 8px 32px #00000066`,
      animation:"fadeSlideIn .3s cubic-bezier(.34,1.5,.64,1)",zIndex:9999}}>
      <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:3}}>
        <div style={{width:6,height:6,borderRadius:"50%",background:notif.color,
          boxShadow:`0 0 6px ${notif.color}`,animation:"pulse 1.5s infinite"}}/>
        <span style={{color:notif.color,fontFamily:"Rajdhani,sans-serif",fontWeight:700,fontSize:13}}>{notif.title}</span>
      </div>
      <div style={{color:C.textMid,fontFamily:"JetBrains Mono,monospace",fontSize:11}}>{notif.msg}</div>
    </div>
  );
}export default function BaoHub(){
  const [booted,setBooted]=useState(false);
  const [visible,setVisible]=useState(false);
  const [activeTab,setTab]=useState("home");
  const [notif,setNotif]=useState(null);
  const notifTimer=useRef(null);

  const [tog,setTog]=useState({
    autoAtk:false,reach:false,infJump:false,
    noclip:false,esp:false,fullbright:false,antiafk:false,
  });

  const [ws,setWs]=useState(16);
  const [jp,setJp]=useState(50);
  const [atk,setAtk]=useState(50);
  const [tx,setTx]=useState("0");
  const [ty,setTy]=useState("50");
  const [tz,setTz]=useState("0");

  const notify=(title,msg,color)=>{
    clearTimeout(notifTimer.current);
    setNotif({title,msg,color:color||C.cyan});
    notifTimer.current=setTimeout(()=>setNotif(null),3500);
  };

  const handleBooted=()=>{
    setBooted(true);
    setTimeout(()=>{
      setVisible(true);
      notify("⚡ BẢO HUB","Đã kích hoạt thành công!",C.cyan);
    },200);
  };

  if(!booted) return(
    <>
      <GlobalStyle/>
      <BootScreen onDone={handleBooted}/>
    </>
  );

  return(
    <>
      <GlobalStyle/>
      <div style={{minHeight:"100vh",background:C.bg,
        display:"flex",alignItems:"center",justifyContent:"center",
        position:"relative",overflow:"hidden"}}>

        <div style={{position:"fixed",inset:0,opacity:.025,
          backgroundImage:`linear-gradient(${C.cyan} 1px,transparent 1px),linear-gradient(90deg,${C.cyan} 1px,transparent 1px)`,
          backgroundSize:"40px 40px",animation:"gridPan 8s linear infinite",pointerEvents:"none"}}/>

        <div style={{position:"fixed",top:"20%",left:"35%",
          width:500,height:400,borderRadius:"50%",
          background:`radial-gradient(ellipse,${C.cyan}07 0%,transparent 65%)`,
          pointerEvents:"none"}}/>

        <div style={{width:600,borderRadius:14,overflow:"hidden",
          border:`1px solid ${C.border}`,
          boxShadow:`0 0 0 1px ${C.cyan}11,0 30px 80px #000000aa,0 0 60px ${C.cyan}0a`,
          backdropFilter:"blur(24px)",background:C.bgPanel,
          transform:visible?"scale(1) translateY(0)":"scale(.96) translateY(16px)",
          opacity:visible?1:0,
          transition:"all .4s cubic-bezier(.34,1.3,.64,1)"}}>

          <Titlebar/>

          <div style={{display:"flex"}}>
            <Sidebar activeTab={activeTab} setTab={setTab} tog={tog}/>
            <div style={{flex:1,padding:"14px 16px",overflowY:"auto",maxHeight:430}}>
              <TabContent
                activeTab={activeTab}
                tog={tog} setTog={setTog}
                ws={ws} setWs={setWs}
                jp={jp} setJp={setJp}
                atk={atk} setAtk={setAtk}
                tx={tx} setTx={setTx}
                ty={ty} setTy={setTy}
                tz={tz} setTz={setTz}
                notify={notify}
              />
            </div>
          </div>

          <Footer/>
        </div>
      </div>

      <Toast notif={notif}/>
    </>
  );
}
