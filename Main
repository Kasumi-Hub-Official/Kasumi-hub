    </div>
  );
}function Sidebar({activeTab,setTab,tog}){
  return(
    <div style={{width:158,background:C.bgSide,borderRight:`1px solid ${C.border}`,
      padding:"10px 8px",display:"flex",flexDirection:"column"}}>
      {TABS.map((tab,i)=>{
        const active=activeTab===tab.id;
        return(
          <button key={tab.id} onClick={()=>setTab(tab.id)} style={{
            display:"flex",alignItems:"center",gap:9,
            padding:"9px 11px",borderRadius:7,marginBottom:3,
            background:active?C.cyanFaint:"transparent",
            border:`1px solid ${active?C.borderLit:"transparent"}`,
            color:active?C.cyan:C.textDim,
            fontFamily:"Rajdhani,sans-serif",fontWeight:active?700:500,
            fontSize:13,cursor:"pointer",textAlign:"left",
            transition:"all .18s",
            boxShadow:active?`inset 0 0 16px ${C.cyan}0a`:"none",
            animation:`fadeSlideIn .3s ease ${i*.05}s both`}}>
            <span style={{width:22,height:22,borderRadius:5,flexShrink:0,
              background:active?C.cyan+"22":"transparent",
              display:"flex",alignItems:"center",justifyContent:"center",
              fontSize:13,transition:"background .18s"}}>{tab.icon}</span>
            {tab.label}
            {active&&<div style={{marginLeft:"auto",width:3,height:18,borderRadius:2,
              background:C.cyan,boxShadow:`0 0 8px ${C.cyan}`}}/>}
          </button>
        );
      })}
      <div style={{marginTop:"auto",borderTop:`1px solid ${C.border}`,paddingTop:10}}>
        <div style={{color:C.textDim,fontSize:9,fontFamily:"JetBrains Mono,monospace",
          letterSpacing:1.5,marginBottom:6}}>ĐANG BẬT</div>
        {Object.entries(tog).filter(([,v])=>v).length===0
          ?<div style={{color:C.textDim,fontSize:10,fontFamily:"JetBrains Mono,monospace"}}>— Chưa có</div>
          :Object.entries(tog).filter(([,v])=>v).map(([k])=>(
            <div key={k} style={{display:"flex",alignItems:"center",gap:5,marginBottom:4}}>
              <div style={{width:5,height:5,borderRadius:"50%",background:C.cyan,
                boxShadow:`0 0 5px ${C.cyan}`,animation:"floatDot 2s ease-in-out infinite"}}/>
              <span style={{color:C.cyan,fontSize:10,fontFamily:"JetBrains Mono,monospace"}}>{k}</span>
            </div>
          ))
        }
      </div>
    </div>
  );
}

