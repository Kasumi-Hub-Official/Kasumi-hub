import { useState, useEffect, useRef } from "react";

const C = {
  cyan:"#00ffe7",cyanDim:"#00bfad",cyanGlow:"#00ffe733",cyanFaint:"#00ffe711",
  bg:"#07090f",bgPanel:"#0b0f18",bgSide:"#080b13",bgCard:"#0f1520",
  bgHover:"#131c28",border:"#162030",borderLit:"#00ffe722",
  text:"#d6e8f5",textDim:"#4a6478",textMid:"#7a9ab0",
  red:"#ff4d6d",green:"#00ffaa",yellow:"#ffd166",
};

const TABS = [
  {id:"home",label:"Trang Chủ",icon:"⌂"},
  {id:"combat",label:"Chiến Đấu",icon:"⚔"},
  {id:"player",label:"Người Chơi",icon:"◈"},
  {id:"visual",label:"Hiển Thị",icon:"◉"},
  {id:"misc",label:"Khác",icon:"◎"},
  {id:"config",label:"Cài Đặt",icon:"⚙"},
];

const GlobalStyle = () => (
  <style>{`
    @import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap');
    *{box-sizing:border-box;margin:0;padding:0}
    body{background:#07090f}
    ::-webkit-scrollbar{width:4px}
    ::-webkit-scrollbar-track{background:transparent}
    ::-webkit-scrollbar-thumb{background:#162030;border-radius:2px}
    @keyframes fadeSlideIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
    @keyframes pulse{0%,100%{box-shadow:0 0 6px #00ffe788}50%{box-shadow:0 0 18px #00ffe7cc,0 0 32px #00ffe744}}
    @keyframes borderGlow{0%,100%{border-color:#00ffe722}50%{border-color:#00ffe766}}
    @keyframes floatDot{0%,100%{transform:translateY(0);opacity:.6}50%{transform:translateY(-6px);opacity:1}}
    @keyframes gridPan{from{background-position:0 0}to{background-position:40px 40px}}
    .tab-content{animation:fadeSlideIn .25s ease both}
    .glow-pulse{animation:pulse 2.4s ease-in-out infinite}
  `}</style>
);function Toggle({label,desc,value,onChange,disabled}){
  const [hov,setHov]=useState(false);
  return(
    <div onMouseEnter={()=>setHov(true)} onMouseLeave={()=>setHov(false)}
      onClick={()=>!disabled&&onChange(!value)}
      style={{display:"flex",alignItems:"center",justifyContent:"space-between",
        padding:"11px 14px",borderRadius:8,marginBottom:8,
        cursor:disabled?"not-allowed":"pointer",
        background:hov?C.bgHover:C.bgCard,
        border:`1px solid ${value?C.cyan+"44":C.border}`,
        transition:"all .2s",boxShadow:value?`0 0 16px ${C.cyan}18`:"none",
        opacity:disabled?.4:1}}>
      <div>
        <div style={{color:C.text,fontFamily:"Rajdhani,sans-serif",fontWeight:600,fontSize:13.5,letterSpacing:.3}}>{label}</div>
        {desc&&<div style={{color:C.textDim,fontSize:11,marginTop:1,fontFamily:"JetBrains Mono,monospace"}}>{desc}</div>}
      </div>
      <div style={{width:42,height:23,borderRadius:12,flexShrink:0,position:"relative",
        background:value?`linear-gradient(90deg,${C.cyanDim},${C.cyan})`:C.border,
        transition:"background .25s",boxShadow:value?`0 0 12px ${C.cyan}99`:"none"}}>
        <div style={{position:"absolute",top:3,borderRadius:"50%",
          left:value?22:3,width:17,height:17,background:"#fff",
          boxShadow:value?`0 0 6px ${C.cyan}`:"0 1px 3px #00000066",
          transition:"left .25s cubic-bezier(.34,1.56,.64,1)"}}/>
      </div>
    </div>
  );
}

function Slider({label,value,min,max,unit="",onChange}){
  const pct=((value-min)/(max-min))*100;
  return(
    <div style={{background:C.bgCard,borderRadius:8,padding:"12px 14px",border:`1px solid ${C.border}`,marginBottom:8}}>
      <div style={{display:"flex",justifyContent:"space-between",marginBottom:10}}>
        <span style={{color:C.text,fontFamily:"Rajdhani,sans-serif",fontWeight:600,fontSize:13.5}}>{label}</span>
        <span style={{color:C.cyan,fontFamily:"JetBrains Mono,monospace",fontSize:12,fontWeight:600,
          background:C.cyanFaint,padding:"1px 8px",borderRadius:4,border:`1px solid ${C.cyanGlow}`}}>{value}{unit}</span>
      </div>
      <div style={{position:"relative",height:6,borderRadius:3,background:C.border}}>
        <div style={{position:"absolute",left:0,top:0,height:"100%",borderRadius:3,
          width:`${pct}%`,background:`linear-gradient(90deg,${C.cyanDim},${C.cyan})`,
          boxShadow:`0 0 8px ${C.cyan}66`,transition:"width .08s"}}/>
        <div style={{position:"absolute",top:"50%",transform:"translateY(-50%)",
          left:`calc(${pct}% - 9px)`,width:18,height:18,borderRadius:"50%",
          background:`radial-gradient(circle,${C.cyan},${C.cyanDim})`,
          boxShadow:`0 0 10px ${C.cyan},0 0 20px ${C.cyan}44`,
          border:"2px solid #fff",transition:"left .08s",pointerEvents:"none"}}/>
        <input type="range" min={min} max={max} value={value}
          onChange={e=>onChange(+e.target.value)}
          style={{position:"absolute",inset:0,opacity:0,cursor:"pointer",width:"100%",height:"100%"}}/>
      </div>
      <div style={{display:"flex",justifyContent:"space-between",marginTop:5}}>
        <span style={{color:C.textDim,fontSize:10,fontFamily:"JetBrains Mono,monospace"}}>{min}</span>
        <span style={{color:C.textDim,fontSize:10,fontFamily:"JetBrains Mono,monospace"}}>{max}</span>
      </div>
    </div>
  );
}

function Btn({label,desc,accent,onClick}){
  const [hov,setHov]=useState(false);
  const [press,setPress]=useState(false);
  const col=accent||C.cyan;
  return(
    <button onMouseEnter={()=>setHov(true)} onMouseLeave={()=>{setHov(false);setPress(false)}}
      onMouseDown={()=>setPress(true)} onMouseUp={()=>setPress(false)} onClick={onClick}
      style={{width:"100%",padding:"11px 14px",borderRadius:8,marginBottom:8,
        background:press?col+"33":hov?col+"18":C.bgCard,
        border:`1px solid ${hov||press?col+"66":C.border}`,
        color:col,cursor:"pointer",textAlign:"left",
        fontFamily:"Rajdhani,sans-serif",fontWeight:700,fontSize:13.5,letterSpacing:.4,
        transition:"all .15s",boxShadow:press?`0 0 20px ${col}44`:hov?`0 0 10px ${col}22`:"none",
        transform:press?"scale(.98)":"scale(1)"}}>
      {label}
      {desc&&<div style={{fontWeight:400,fontSize:11,color:C.textMid,marginTop:2,fontFamily:"JetBrains Mono,monospace"}}>{desc}</div>}
    </button>
  );
}

function StatBadge({label,value,color}){
  return(
    <div style={{flex:1,background:C.bgCard,borderRadius:8,
      border:`1px solid ${(color||C.cyan)+"33"}`,padding:"10px 12px",textAlign:"center"}}>
      <div style={{color:color||C.cyan,fontFamily:"JetBrains Mono,monospace",fontSize:18,fontWeight:600}}>{value}</div>
      <div style={{color:C.textDim,fontSize:10,marginTop:3,fontFamily:"Rajdhani,sans-serif",letterSpacing:.5}}>{label}</div>
    </div>
  );
}

function SectionHead({label}){
  return(
    <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:10,marginTop:4}}>
      <div style={{width:3,height:14,borderRadius:2,background:C.cyan,boxShadow:`0 0 8px ${C.cyan}`}}/>
      <span style={{color:C.textMid,fontSize:10,fontFamily:"Rajdhani,sans-serif",fontWeight:700,letterSpacing:2,textTransform:"uppercase"}}>{label}</span>
      <div style={{flex:1,height:1,background:`linear-gradient(90deg,${C.border},transparent)`}}/>
    </div>
  );
}function BootScreen({onDone}){
  const [pct,setPct]=useState(0);
  const [line,setLine]=useState(0);
  const lines=[
    "> Initializing BẢO HUB...",
    "> Loading Fluent UI Library...",
    "> Injecting modules...",
    "> Bypassing detection...",
    "> Ready.",
  ];
  useEffect(()=>{
    const t=setInterval(()=>{
      setPct(p=>{
        if(p>=100){clearInterval(t);setTimeout(onDone,400);return 100;}
        return p+2;
      });
    },30);
    return()=>clearInterval(t);
  },[]);
  useEffect(()=>{setLine(Math.floor((pct/100)*lines.length));},[pct]);
  return(
    <div style={{position:"fixed",inset:0,background:C.bg,zIndex:999,
      display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",
      fontFamily:"JetBrains Mono,monospace"}}>
      <div style={{position:"absolute",inset:0,opacity:.04,
        backgroundImage:`linear-gradient(${C.cyan} 1px,transparent 1px),linear-gradient(90deg,${C.cyan} 1px,transparent 1px)`,
        backgroundSize:"40px 40px",animation:"gridPan 3s linear infinite"}}/>
      <div style={{textAlign:"center",position:"relative"}}>
        <div style={{fontSize:42,fontFamily:"Rajdhani,sans-serif",fontWeight:700,
          color:C.cyan,letterSpacing:6,
          textShadow:`0 0 30px ${C.cyan},0 0 60px ${C.cyan}44`,
          marginBottom:4}}>BẢO HUB</div>
        <div style={{color:C.textDim,fontSize:11,letterSpacing:3,marginBottom:32}}>SIÊU SIÊU MẠNH • v3.0</div>
        <div style={{width:320,height:3,background:C.border,borderRadius:2,marginBottom:16,overflow:"hidden"}}>
          <div style={{height:"100%",borderRadius:2,width:`${pct}%`,
            background:`linear-gradient(90deg,${C.cyanDim},${C.cyan})`,
            boxShadow:`0 0 10px ${C.cyan}`,transition:"width .03s"}}/>
        </div>
        <div style={{textAlign:"left",width:320}}>
          {lines.slice(0,line+1).map((l,i)=>(
            <div key={i} style={{color:i===line?C.cyan:C.textDim,fontSize:11,marginBottom:3,
              animation:"fadeSlideIn .2s ease both"}}>
              {l}{i===line&&pct<100&&<span>█</span>}
            </div>
          ))}
        </div>
        <div style={{color:C.textDim,fontSize:10,marginTop:16}}>{pct}%</div>
      </div>
    </div>
  );
}

